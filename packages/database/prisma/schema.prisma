generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StoreStatus {
  CONNECTED
  DISCONNECTED
}

enum AbandonedStatus {
  DETECTED
  RECOVERED
  EXPIRED
}

enum PlanType {
  FREE
  STARTER
  PRO
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  EXPIRED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  fullName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resetToken        String?
  resetTokenExpires DateTime?

  // Account-level communication credentials
  smtpHost     String?
  smtpPort     Int     @default(587)
  smtpUser     String?
  smtpPass     String?
  smtpFrom     String?
  smtpSecure   Boolean @default(false)
  smtpVerified Boolean @default(false)

  twilioAccountSid  String?
  twilioAuthToken   String?
  twilioFromPhone   String?
  twilioWhatsappNum String?

  // Plan & usage
  plan          PlanType @default(FREE)
  planExpiresAt DateTime?

  ordersUsed     Int      @default(0)
  emailsUsed     Int      @default(0)
  smsUsed        Int      @default(0)
  whatsappUsed   Int      @default(0)
  usageResetAt   DateTime @default(now())

  // Custom limits (admin override)
  customOrderLimit    Int?
  customEmailLimit    Int?
  customSmsLimit      Int?
  customWhatsappLimit Int?

  // Admin & tracking
  isAdmin       Boolean  @default(false)
  lastLoginIp   String?
  lastLoginAt   DateTime?
  country       String?
  city          String?

  stores   Store[]
  payments Payment[]
}

model Payment {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  plan           PlanType
  amountUsd      Float
  nowPaymentId   String?       @unique
  invoiceId      String?       @unique
  paymentUrl     String?
  status         PaymentStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Store {
  id                    String      @id @default(cuid())
  name                  String
  domain                String      @unique
  apiKey                String      @unique
  apiSecret             String
  webhookSecret         String
  status                StoreStatus @default(DISCONNECTED)
  abandonmentTimeoutMin Int         @default(180)

  smtpHost     String?
  smtpPort     Int     @default(587)
  smtpUser     String?
  smtpPass     String?
  smtpFrom     String?
  smtpSecure   Boolean @default(false)
  smtpVerified Boolean @default(false)

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  abandonedOrders AbandonedOrder[]
  campaigns       Campaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AbandonedOrder {
  id String @id @default(cuid())

  externalOrderId String
  sessionId       String?

  customerEmail String?
  customerPhone String?
  customerName  String?

  cartValue    Float?
  cartSnapshot Json?

  orderStatus String?
  isAbandoned Boolean @default(false)

  status AbandonedStatus @default(DETECTED)

  abandonedAt  DateTime?
  recoveredAt  DateTime?
  emailSentAt  DateTime?

  // Multi-step sequence tracking
  emailStep2SentAt DateTime?
  emailStep3SentAt DateTime?
  whatsappSentAt   DateTime?
  smsSentAt        DateTime?

  // A/B testing
  abVariant String? // 'A' | 'B'

  // Analytics tracking
  emailOpenedAt   DateTime?
  emailClickedAt  DateTime?
  recoveredBy     String?   // 'EMAIL' | 'WHATSAPP' | 'SMS'
  recoveredByStep Int?      // 1, 2, or 3

  // Visitor intelligence (captured on open/click)
  customerIp      String?
  customerCountry String?
  customerCity    String?
  customerRegion  String?
  customerIsp     String?
  customerDevice  String?   // mobile | tablet | desktop
  customerBrowser String?
  customerOs      String?

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Campaign {
  id String @id @default(cuid())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  emailEnabled    Boolean @default(true)
  whatsappEnabled Boolean @default(false)
  smsEnabled      Boolean @default(false)

  emailDelayMin    Int @default(30)
  whatsappDelayMin Int @default(60)
  smsDelayMin      Int @default(120)

  emailTemplate    String?
  whatsappTemplate String?
  smsTemplate      String?

  // Which built-in template style to use when emailTemplate is null
  templateId       String  @default("classic") // classic | minimal | urgent | friendly

  // Email sequence step 2 (e.g. 24h follow-up)
  emailStep2DelayMin Int?
  emailStep2Subject  String?
  emailStep2Template String?

  // Email sequence step 3 (e.g. 72h follow-up)
  emailStep3DelayMin Int?
  emailStep3Subject  String?
  emailStep3Template String?

  // A/B testing on step 1
  abTestEnabled     Boolean @default(false)
  abVariantBSubject String?
  abVariantBTemplate String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
